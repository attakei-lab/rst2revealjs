{
  "name": "live-preview-for-rst2revealjs",
  "version": "0.0.0",
  "module": "index.ts",
  "main": "out/extension.js",
  "type": "module",
  "private": true,
  "repository": {
    "url": "https://gitbu.com/atsphinx/rst2revealjs",
    "directory": "ide-extensions/vscode"
  },
  "engines": {
    "vscode": "^1.106.0"
  },
  "scripts": {
    "build": "bun build src/extension.ts --outdir=out/ --external vscode --target node",
    "package": "vsce package --no-dependencies"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "vsce": "^2.15.0",
    "vscode": "^1.1.37"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "publisher": "attakei",
  "displayName": "Live Preview for rst2revealjs",
  "activationEvents": [
    "onLanguage:markdown",
    "onLanguage:restructuredtext"
  ],
  "contributes": {
    "commands": [
      {
        "command": "live-preview-for-rst2revealjs.startPreview",
        "title": "Start Live Preview",
        "category": "rst2revealjs"
      }
    ]
  }
}
